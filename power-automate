var EMS = EMS || {};
EMS.ImportCycle = EMS.ImportCycle || {};

// Map BPF stage names to form tab names
// IMPORTANT: These must match EXACTLY the BPF stage names and the tab names on the form
EMS.ImportCycle.stageToTabMap = {
    "Stage 1 - Review Changes": "tab_stage1",
    "Stage 2 - Classify Controls": "tab_stage2",
    "Stage 3 - Map Applicability": "tab_stage3",
    "Stage 4 - Review Evidence": "tab_stage4",
    "Stage 5 - Confirm": "tab_stage5"
};

// Called when form loads and on BPF stage change
EMS.ImportCycle.onStageChange = function(executionContext) {
    var formContext = executionContext.getFormContext();
    var activeStage = formContext.data.process.getActiveStage();
    
    if (!activeStage) {
        return;
    }
    
    var stageName = activeStage.getName();
    var targetTabName = EMS.ImportCycle.stageToTabMap[stageName];
    
    if (targetTabName) {
        var tab = formContext.ui.tabs.get(targetTabName);
        if (tab) {
            tab.setFocus();
        }
    }
};

// Called on form load — also triggers initial tab switch
EMS.ImportCycle.onLoad = function(executionContext) {
    var formContext = executionContext.getFormContext();
    
    // Register stage change handler
    formContext.data.process.addOnStageChange(EMS.ImportCycle.onStageChange);
    
    // Switch to current stage's tab on load
    EMS.ImportCycle.onStageChange(executionContext);
};
