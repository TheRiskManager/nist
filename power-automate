var EMS = EMS || {};
EMS.ImportCycle = EMS.ImportCycle || {};

// Map BPF stage display names to form tab names
EMS.ImportCycle.stageToTabMap = {
    "Stage 1 - Review Changes": "tab_2",
    "Stage 2 - Classify Controls": "tab_3",
    "Stage 3 - Map Applicability": "tab_4",
    "Stage 4 - Review Evidence": "tab_5",
    "Stage 5 - Confirm": "tab_6"
};

// Shared tab-switcher used by both stage change and stage selected handlers
EMS.ImportCycle.switchTabForStage = function(formContext, stage) {
    if (!stage) return;
    
    var stageName = stage.getName();
    var targetTabName = EMS.ImportCycle.stageToTabMap[stageName];
    
    if (targetTabName) {
        var tab = formContext.ui.tabs.get(targetTabName);
        if (tab) {
            tab.setFocus();
        }
    }
};

// Fires when the active BPF stage advances (gate ticked, etc.)
EMS.ImportCycle.onStageChange = function(executionContext) {
    var formContext = executionContext.getFormContext();
    EMS.ImportCycle.switchTabForStage(formContext, formContext.data.process.getActiveStage());
};

// Fires when user clicks a BPF stage circle (no advancement, just selection)
EMS.ImportCycle.onStageSelected = function(executionContext) {
    var formContext = executionContext.getFormContext();
    var selectedStage = executionContext.getEventArgs().getStage();
    EMS.ImportCycle.switchTabForStage(formContext, selectedStage);
};

// Registers both handlers — does NOT auto-switch on load (Overview is default landing)
EMS.ImportCycle.onLoad = function(executionContext) {
    var formContext = executionContext.getFormContext();
    formContext.data.process.addOnStageChange(EMS.ImportCycle.onStageChange);
    formContext.data.process.addOnStageSelected(EMS.ImportCycle.onStageSelected);
};
